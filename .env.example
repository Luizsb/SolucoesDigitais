OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
API_PORT=8787

# Supabase — grava pedidos na tabela revisao_solicitacoes (ver scripts/README-SUPABASE.md e scripts/supabase-revisao.sql)
# Vite exige prefixo VITE_ (não use NEXT_PUBLIC_* do wizard Next.js sem renomear).
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# ou legacy: VITE_SUPABASE_ANON_KEY=<JWT anon>

# Envio para a aba solucoes_revisao (Google Apps Script → Implementar como aplicação Web → URL /exec)
#
# Produção / `vite build`: URL completa /exec — atenção: domínios `script.google.com/a/macros/...` (Workspace)
# muitas vezes não enviam `Access-Control-Allow-Origin` para o teu site; aí é preciso um proxy no mesmo domínio
# (ex.: Cloudflare Worker, Azure Function) ou política da org a permitir CORS.
# VITE_APPS_SCRIPT_WEB_APP_URL=https://script.google.com/.../exec
#
# `npm run dev`: evita CORS — o browser só fala com localhost; o Vite reencaminha para o Google.
# GAS_REVISAO_UPSTREAM_URL=https://script.google.com/.../exec
# VITE_APPS_SCRIPT_WEB_APP_URL=/__gas_revisao
#
# Opcional: mesma string que a propriedade REVIEW_INGEST_SECRET no projeto Apps Script
VITE_APPS_SCRIPT_WEB_APP_URL=
VITE_APPS_SCRIPT_INGEST_SECRET=

# Opcional: Client ID OAuth (tipo Web) — botão «Continuar com Google» no envio à planilha (ver scripts/README-APPS-SCRIPT.md)
# VITE_GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Alternativa quando TI não permite Web App pública / fetch cross-origin: URL do Google Form (abre com sessão Arco)
# Se definido, o site NÃO chama o Apps Script; após validar, mostra link para concluir no formulário.
# VITE_REVISAO_GOOGLE_FORM_URL=https://docs.google.com/forms/d/e/.../viewform
